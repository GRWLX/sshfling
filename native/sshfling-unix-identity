#!/bin/sh
set -eu
set -f

LC_ALL=C
PATH='/usr/sbin:/usr/bin:/sbin:/bin:/run/current-system/sw/bin:/nix/var/nix/profiles/default/bin:/run/current-system/profile/bin:/var/guix/profiles/system/profile/bin'
export LC_ALL PATH

die() {
  message=$1
  code=${2:-1}
  printf 'sshfling-unix-identity: %s\n' "$message" >&2
  exit "$code"
}

stat_owner_mode() {
  path=$1
  if values=$(stat -c '%u %a' "$path" 2>/dev/null); then
    :
  elif values=$(stat -f '%u %Lp' "$path" 2>/dev/null); then
    :
  else
    return 1
  fi
  owner=${values%% *}
  mode=${values#* }
  [ -n "$owner" ] && [ -n "$mode" ] && [ "$mode" = "${mode##* }" ] || return 1
  printf '%s %s\n' "$owner" "$mode"
}

trusted_tool_directory() {
  path=$1
  case "$path" in
    */|*//*|*/./*|*/../*|*/.|*/..) return 1 ;;
    /*) ;;
    *) return 1 ;;
  esac
  current=
  old_ifs=$IFS
  IFS=/
  # Globbing is disabled before this intentional component split.
  # shellcheck disable=SC2086
  set -- ${path#/}
  IFS=$old_ifs
  [ "$path" != / ] && [ "$#" -gt 0 ] || return 1
  current_uid=
  for component do
    [ -n "$component" ] || return 1
    current=$current/$component
    [ -d "$current" ] && [ ! -L "$current" ] || return 1
    values=$(stat_owner_mode "$current") || return 1
    owner=${values%% *}
    mode=${values#* }
    case "$owner" in ''|*[!0-9]*) return 1 ;; esac
    case "$mode" in
      ???|????) ;;
      *) return 1 ;;
    esac
    case "$mode" in *[!0-7]*) return 1 ;; esac
    if [ "$owner" != 0 ]; then
      if [ -z "$current_uid" ]; then
        current_uid=$(command -p id -u 2>/dev/null) || return 1
      fi
      [ "$current_uid" != 0 ] && [ "$owner" = "$current_uid" ] || return 1
    fi
    permissions=${mode#"${mode%???}"}
    group_digit=$(printf '%s' "$permissions" | cut -c 2)
    other_digit=$(printf '%s' "$permissions" | cut -c 3)
    writable=0
    case "$group_digit$other_digit" in
      *[2367]*) writable=1 ;;
    esac
    if [ "$writable" -eq 1 ]; then
      case "$mode" in
        1???|3???|5???|7???) : ;;
        *) return 1 ;;
      esac
    fi
    if [ "$current" = "$path" ] && [ "$writable" -eq 1 ]; then
      return 1
    fi
  done
}

native_tool_directory=${SSHFLING_NATIVE_TOOL_DIR:-}
native_tool_path=${SSHFLING_NATIVE_TOOL_PATH:-}
unset SSHFLING_NATIVE_TOOL_DIR SSHFLING_NATIVE_TOOL_PATH
if [ -n "$native_tool_directory" ]; then
  trusted_tool_directory "$native_tool_directory" \
    || die "refusing unsafe native tool directory: $native_tool_directory" 77
  PATH=$native_tool_directory:$PATH
fi
if [ -n "$native_tool_path" ]; then
  case "$native_tool_path" in
    :*|*:|*::* ) die "refusing an empty native tool path entry" 77 ;;
  esac
  remaining_tool_path=$native_tool_path
  while [ -n "$remaining_tool_path" ]; do
    case "$remaining_tool_path" in
      *:*)
        native_tool_directory=${remaining_tool_path%%:*}
        remaining_tool_path=${remaining_tool_path#*:}
        ;;
      *)
        native_tool_directory=$remaining_tool_path
        remaining_tool_path=
        ;;
    esac
    [ -n "$native_tool_directory" ] \
      || die "refusing an empty native tool path entry" 77
    trusted_tool_directory "$native_tool_directory" \
      || die "refusing unsafe native tool directory: $native_tool_directory" 77
    PATH=$native_tool_directory:$PATH
  done
fi
export PATH
unset native_tool_directory native_tool_path remaining_tool_path

validate_username() {
  username=$1
  case "$username" in
    ''|[0-9-]*|*[!a-z0-9_-]*)
      die "invalid Unix username: $username" 2
      ;;
  esac
  [ "${#username}" -le 32 ] || die "invalid Unix username: $username" 2
}

require_tool() {
  command -v "$1" >/dev/null 2>&1 || die "missing command: $1" 127
}

emit_missing() {
  printf 'result\tstatus=missing\tuser=%s\n' "$1"
}

emit_present() {
  username=$1
  fields=$2
  printf 'result\tstatus=present\tuser=%s\t%s\n' "$username" "$fields"
}

parse_passwd_entry() {
  username=$1
  entry=$2
  printf '%s\n' "$entry" | awk -F: -v expected="$username" '
    NF != 7 || $1 != expected || $3 !~ /^[0-9]+$/ || $4 !~ /^[0-9]+$/ ||
        $6 == "" || index($6, "\t") || index($6, "\r") {
      exit 1
    }
    { printf "uid=%s\tgid=%s\thome=%s\n", $3, $4, $6 }
  '
}

parse_directory_record() {
  username=$1
  name_key=$2
  uid_key=$3
  gid_key=$4
  home_key=$5
  record=$6
  printf '%s\n' "$record" | awk \
    -v expected="$username" \
    -v name_key="$name_key" \
    -v uid_key="$uid_key" \
    -v gid_key="$gid_key" \
    -v home_key="$home_key" '
    function trim(value) {
      sub(/^[[:space:]]+/, "", value)
      sub(/[[:space:]]+$/, "", value)
      return value
    }
    {
      separator = index($0, ":")
      if (!separator) next
      raw_key = substr($0, 1, separator - 1)
      raw_value = substr($0, separator + 1)
      key = trim(raw_key)
      value = trim(raw_value)
      if ((key == name_key || key == uid_key || key == gid_key || key == home_key) &&
          (index(raw_key, "\t") || index(raw_key, "\r") ||
           index(raw_value, "\t") || index(raw_value, "\r"))) {
        invalid = 1
      }
      if (key == name_key) { name = value; name_count++ }
      if (key == uid_key) { uid = value; uid_count++ }
      if (key == gid_key) { gid = value; gid_count++ }
      if (key == home_key) { home = value; home_count++ }
    }
    END {
      if (name_count != 1 || uid_count != 1 || gid_count != 1 || home_count != 1 ||
          invalid || name != expected || uid !~ /^[0-9]+$/ || gid !~ /^[0-9]+$/ || home == "" ||
          index(home, "\t") || index(home, "\r")) {
        exit 1
      }
      printf "uid=%s\tgid=%s\thome=%s\n", uid, gid, home
    }
  '
}

lookup_getent() {
  username=$1
  require_tool getent

  if entry=$(getent passwd "$username" 2>/dev/null); then
    [ -n "$entry" ] || die "getent returned an empty passwd record for $username"
  else
    status=$?
    if [ "$status" -eq 2 ]; then
      emit_missing "$username"
      return 0
    fi
    die "getent passwd lookup failed for $username (exit $status)"
  fi

  case "$entry" in
    *'
'*) die "getent returned multiple passwd records for $username" ;;
  esac
  if ! fields=$(parse_passwd_entry "$username" "$entry"); then
    die "getent returned a malformed passwd record for $username"
  fi
  emit_present "$username" "$fields"
}

lookup_passwd_file() {
  username=$1
  passwd_directory=/etc
  passwd_path=$passwd_directory/passwd

  trusted_tool_directory "$passwd_directory" \
    || die "refusing unsafe passwd directory: $passwd_directory" 77
  if [ -L "$passwd_path" ]; then
    values=$(stat_owner_mode "$passwd_path") \
      || die "could not inspect passwd link: $passwd_path"
    link_owner=${values%% *}
    [ "$link_owner" = 0 ] \
      || die "refusing non-root-owned passwd link: $passwd_path" 77
    require_tool readlink
    passwd_file=$(readlink -f "$passwd_path" 2>/dev/null) \
      || die "could not resolve passwd link: $passwd_path"
    case "$passwd_file" in
      /nix/store/*/etc/passwd) ;;
      *) die "refusing passwd link outside the Nix store: $passwd_path" 77 ;;
    esac
    trusted_tool_directory "${passwd_file%/*}" \
      || die "refusing unsafe passwd target directory: ${passwd_file%/*}" 77
  else
    passwd_file=$passwd_path
  fi
  if [ ! -f "$passwd_file" ] || [ -L "$passwd_file" ] || [ ! -r "$passwd_file" ]; then
    die "refusing unsafe passwd file: $passwd_file" 77
  fi

  values=$(stat_owner_mode "$passwd_file") \
    || die "could not inspect passwd file: $passwd_file"
  owner=${values%% *}
  mode=${values#* }
  case "$owner" in ''|*[!0-9]*) die "invalid passwd file owner: $passwd_file" ;; esac
  case "$mode" in
    ???|????) ;;
    *) die "invalid passwd file mode: $passwd_file" ;;
  esac
  [ "$owner" = 0 ] || die "refusing non-root-owned passwd file: $passwd_file" 77

  permissions=${mode#"${mode%???}"}
  group_digit=$(printf '%s' "$permissions" | cut -c 2)
  other_digit=$(printf '%s' "$permissions" | cut -c 3)
  case "$group_digit$other_digit" in
    *[2367]*) die "refusing writable passwd file: $passwd_file" 77 ;;
  esac

  if lookup=$(awk -F: -v expected="$username" '
    $1 == expected { matches++; entry = $0 }
    END {
      if (matches == 0) { print "missing"; exit }
      if (matches > 1) { print "multiple"; exit }
      printf "present\t%s\n", entry
    }
  ' "$passwd_file" 2>/dev/null); then
    :
  else
    status=$?
    die "passwd file lookup failed for $username (exit $status)"
  fi

  case "$lookup" in
    missing)
      emit_missing "$username"
      return 0
      ;;
    multiple)
      die "passwd file returned multiple records for $username"
      ;;
    present'	'*) entry=${lookup#present'	'} ;;
    *) die "passwd file lookup returned an invalid result for $username" ;;
  esac
  if ! fields=$(parse_passwd_entry "$username" "$entry"); then
    die "passwd file returned a malformed record for $username"
  fi
  emit_present "$username" "$fields"
}

lookup_unix() {
  username=$1
  if command -v getent >/dev/null 2>&1; then
    lookup_getent "$username"
  else
    lookup_passwd_file "$username"
  fi
}

lookup_dscacheutil() {
  username=$1
  if record=$(dscacheutil -q user -a name "$username" 2>/dev/null); then
    if [ -z "$record" ]; then
      emit_missing "$username"
      return 0
    fi
  else
    status=$?
    die "dscacheutil lookup failed for $username (exit $status)"
  fi

  if ! fields=$(parse_directory_record \
    "$username" name uid gid dir "$record"); then
    die "dscacheutil returned a malformed user record for $username"
  fi
  emit_present "$username" "$fields"
}

lookup_dscl() {
  username=$1
  if users=$(dscl . -list /Users 2>/dev/null); then
    :
  else
    status=$?
    die "dscl user listing failed (exit $status)"
  fi

  if ! printf '%s\n' "$users" | awk -v expected="$username" \
    '$0 == expected { found = 1 } END { exit(found ? 0 : 1) }'; then
    emit_missing "$username"
    return 0
  fi

  if record=$(dscl . -read "/Users/$username" \
    RecordName UniqueID PrimaryGroupID NFSHomeDirectory 2>/dev/null); then
    :
  else
    status=$?
    die "dscl user lookup failed for $username (exit $status)"
  fi
  [ -n "$record" ] || die "dscl returned an empty user record for $username"

  if ! fields=$(parse_directory_record \
    "$username" RecordName UniqueID PrimaryGroupID NFSHomeDirectory "$record"); then
    die "dscl returned a malformed user record for $username"
  fi
  emit_present "$username" "$fields"
}

lookup_darwin() {
  username=$1
  if command -v dscacheutil >/dev/null 2>&1; then
    lookup_dscacheutil "$username"
  elif command -v dscl >/dev/null 2>&1; then
    lookup_dscl "$username"
  else
    die "missing command: dscacheutil or dscl" 127
  fi
}

if [ "$#" -ne 2 ] || [ "$1" != identity ]; then
  die "usage: identity USER" 2
fi
validate_username "$2"
require_tool awk
require_tool uname

operating_system=$(uname -s 2>/dev/null) \
  || die "could not identify the operating system"
case "$operating_system" in
  Linux|FreeBSD|OpenBSD|NetBSD|DragonFly|SunOS)
    lookup_unix "$2"
    ;;
  Darwin)
    lookup_darwin "$2"
    ;;
  *)
    die "unsupported operating system: $operating_system"
    ;;
esac
