{
  "name": "sshfling-tcl",
  "version": "0.0.0",
  "surface": "library-and-cli",
  "library": true,
  "runtime_requirement": "Tcl 8.6 or newer and Python 3",
  "interfaces": {
    "load": "lappend auto_path /prefix/lib/sshfling; package require sshfling",
    "version": "::sshfling::version",
    "runtime_path": "::sshfling::runtime_path",
    "template_dir": "::sshfling::template_dir",
    "launch": "::sshfling::run ?arg ...?",
    "cli": "/prefix/bin/sshfling ?arg ...?"
  },
  "bundles": [
    "canonical Python runtime",
    "canonical deployment templates"
  ]
}
