#!/bin/sh
set -eu

script_path=$0
while [ -L "$script_path" ]; do
    link_target=$(readlink "$script_path") || exit 127
    case "$link_target" in
        /*) script_path=$link_target ;;
        *) script_path=$(dirname "$script_path")/$link_target ;;
    esac
done
script_dir=$(CDPATH='' cd -P "$(dirname "$script_path")" && pwd)
package_root=$(CDPATH='' cd -P "$script_dir/.." && pwd)
awk_command=${AWK:-awk}

if ! command -v "$awk_command" >/dev/null 2>&1; then
    echo "sshfling: AWK is required; set AWK to its executable" >&2
    exit 127
fi

if [ -z "${SSHFLING_PYTHON:-}" ]; then
    if command -v python3 >/dev/null 2>&1; then
        SSHFLING_PYTHON=python3
    elif command -v python >/dev/null 2>&1; then
        SSHFLING_PYTHON=python
    else
        echo "sshfling: Python 3 is required; set SSHFLING_PYTHON to its executable" >&2
        exit 127
    fi
fi

SSHFLING_PACKAGE_ROOT=$package_root
export SSHFLING_PACKAGE_ROOT SSHFLING_PYTHON
exec "$awk_command" \
    -f "$package_root/share/sshfling/awk/sshfling.awk" \
    -f "$package_root/share/sshfling/awk/cli.awk" \
    -- "$@"
