{
  "name": "sshfling-elvish",
  "version": "0.0.0",
  "surface": "elvish-module-and-cli",
  "library": false,
  "runtime_requirement": "Elvish 0.20 or newer and Python 3",
  "interfaces": {
    "module": "Set SSHFLING_PACKAGE_ROOT and XDG_DATA_HOME=/prefix/share, then use sshfling",
    "version": "sshfling:version",
    "runtime_path": "sshfling:runtime-path",
    "template_dir": "sshfling:template-dir",
    "launch": "sshfling:run ?arg ...?",
    "cli": "/prefix/bin/sshfling ?arg ...?"
  },
  "bundles": [
    "canonical Python runtime",
    "canonical deployment templates"
  ]
}
