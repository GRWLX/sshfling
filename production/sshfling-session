#!/usr/bin/env bash
set -euo pipefail

max_seconds=300
max_allowed_seconds=86400
max_allowed_connections=10
grant_max_connections=""
username="unknown"
login_user=""
policy_file="/etc/sshfling/policy.json"
expires_at=""
allow_detached_start=0
session_lock_root=""
provision_lock_user=""
jq_command="jq"

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --allow-detached-start)
      allow_detached_start=1
      shift
      ;;
    --max-seconds)
      max_seconds="${2:-}"
      shift 2
      ;;
    --username)
      username="${2:-}"
      shift 2
      ;;
    --login-user)
      login_user="${2:-}"
      shift 2
      ;;
    --policy-file)
      policy_file="${2:-}"
      shift 2
      ;;
    --expires-at)
      expires_at="${2:-}"
      shift 2
      ;;
    --max-connections)
      grant_max_connections="${2:-}"
      shift 2
      ;;
    --lock-root)
      session_lock_root="${2:-}"
      shift 2
      ;;
    --provision-locks)
      provision_lock_user="${2:-}"
      shift 2
      ;;
    --jq-bin)
      jq_command="${2:-}"
      shift 2
      ;;
    *)
      echo "Unknown sshfling-session option: $1" >&2
      exit 2
      ;;
  esac
done

default_session_lock_root() {
  local operating_system

  operating_system="$(uname -s 2>/dev/null)" || return 1
  case "$operating_system" in
    Darwin) printf '%s\n' /private/var/db/sshfling/session-locks ;;
    FreeBSD|OpenBSD|NetBSD|DragonFly) printf '%s\n' /var/db/sshfling/session-locks ;;
    *) printf '%s\n' /var/lib/sshfling/session-locks ;;
  esac
}

stat_number() {
  local gnu_format="$1"
  local bsd_format="$2"
  local path="$3"
  local value

  if value="$(stat -c "$gnu_format" "$path" 2>/dev/null)"; then
    :
  elif value="$(stat -f "$bsd_format" "$path" 2>/dev/null)"; then
    :
  else
    return 1
  fi
  [[ "$value" =~ ^[0-9]+$ ]] || return 1
  printf '%s\n' "$value"
}

root_managed_directory() {
  local path="$1"
  local owner mode mode_value

  [[ -d "$path" && ! -L "$path" ]] || return 1
  owner="$(stat_number %u %u "$path")" || return 1
  mode="$(stat_number %a %Lp "$path")" || return 1
  [[ "$owner" == 0 ]] || return 1
  mode_value=$(( 8#$mode ))
  (( (mode_value & 0022) == 0 ))
}

validate_lock_path_components() {
  local path="$1"
  local require_all="$2"
  local current=""
  local component
  local -a components=()

  [[ "$path" == /* && "$path" != *$'\n'* && "$path" != *$'\r'* && "$path" != *$'\t'* ]] \
    || return 1
  [[ "/${path#/}/" != *'/../'* && "/${path#/}/" != *'/./'* ]] || return 1
  IFS=/ read -r -a components <<<"${path#/}"
  root_managed_directory / || return 1
  for component in "${components[@]}"; do
    [[ -n "$component" ]] || return 1
    current="${current}/${component}"
    if [[ -e "$current" || -L "$current" ]]; then
      root_managed_directory "$current" || return 1
    elif [[ "$require_all" == 1 ]]; then
      return 1
    fi
  done
}

provision_session_locks() {
  local target_user="$1"
  local uid gid user_lock_dir lock_file owner slot

  (( EUID == 0 )) || {
    echo "sshfling-session lock provisioning requires root privileges." >&2
    return 77
  }
  [[ "$target_user" =~ ^[a-z_][a-z0-9_-]{0,31}$ ]] || {
    echo "Invalid lock-provisioning username: $target_user" >&2
    return 2
  }
  for tool in id mkdir stat chown chgrp chmod; do
    command -v "$tool" >/dev/null 2>&1 || {
      echo "$tool is required to provision sshfling session locks." >&2
      return 127
    }
  done
  uid="$(id -u "$target_user" 2>/dev/null)" || {
    echo "Cannot provision session locks for missing user: $target_user" >&2
    return 1
  }
  gid="$(id -g "$target_user" 2>/dev/null)" || return 1
  [[ "$uid" =~ ^(0|[1-9][0-9]*)$ && "$gid" =~ ^(0|[1-9][0-9]*)$ ]] || return 1
  validate_lock_path_components "$session_lock_root" 0 || {
    echo "Refusing an unsafe sshfling session lock path: $session_lock_root" >&2
    return 1
  }

  user_lock_dir="${session_lock_root%/}/${uid}"
  (umask 022; mkdir -p "$user_lock_dir") || return 1
  chown 0 "$session_lock_root" "$user_lock_dir"
  chgrp 0 "$session_lock_root" "$user_lock_dir"
  chmod 0755 "$session_lock_root" "$user_lock_dir"
  validate_lock_path_components "$user_lock_dir" 1 || {
    echo "Could not secure sshfling session lock directories." >&2
    return 1
  }

  slot=1
  while (( slot <= 10 )); do
    lock_file="${user_lock_dir}/session-${slot}.lock"
    if [[ -L "$lock_file" || ( -e "$lock_file" && ! -f "$lock_file" ) ]]; then
      echo "Refusing unsafe sshfling session lock file: $lock_file" >&2
      return 1
    fi
    if [[ ! -e "$lock_file" ]]; then
      (umask 077; set -o noclobber; : >"$lock_file") || return 1
    fi
    chown "$uid" "$lock_file"
    chgrp "$gid" "$lock_file"
    chmod 0400 "$lock_file"
    owner="$(stat_number %u %u "$lock_file")" || return 1
    [[ -f "$lock_file" && ! -L "$lock_file" && "$owner" == "$uid" ]] || return 1
    slot=$(( slot + 1 ))
  done
  printf 'result\tstatus=provisioned\tuser=%s\tuid=%s\tslots=10\tlock_root=%s\n' \
    "$target_user" "$uid" "$user_lock_dir"
}

if [[ -z "$session_lock_root" ]]; then
  session_lock_root="$(default_session_lock_root)" || {
    echo "Could not determine the sshfling session lock path." >&2
    exit 1
  }
fi

if [[ -n "$provision_lock_user" ]]; then
  provision_session_locks "$provision_lock_user"
  exit $?
fi

if [[ -z "$login_user" ]]; then
  login_user="$(id -un 2>/dev/null || true)"
fi

audit_log() {
  local event="$1"
  shift || true
  if command -v logger >/dev/null 2>&1; then
    logger -t sshfling-session -- "event=${event} program=sshfling-session pid=$$ uid=$(id -u 2>/dev/null || printf unknown) username=${username} login_user=${login_user} $*" >/dev/null 2>&1 || true
  fi
}

read_policy_limits() {
  local path="$1"
  local target_user="$2"
  local jq_bin="$jq_command"
  local values

  if ! command -v "$jq_bin" >/dev/null 2>&1; then
    echo "jq is required to enforce the sshfling session policy." >&2
    return 127
  fi

  # The expression below is evaluated by jq, not the shell.
  # shellcheck disable=SC2016
  values="$("$jq_bin" -er --arg target "$target_user" '
    def field_or($name; $fallback):
      if has($name) then .[$name] else $fallback end;
    def valid_integer($maximum):
      type == "number" and floor == . and . >= 1 and . <= $maximum;
    def valid_access_level:
      type == "string"
      and (
        ascii_downcase
        | gsub("[_ ]"; "-")
        | . == "standard"
          or . == "standard-user"
          or . == "user"
          or . == "operator"
          or . == "ops"
          or . == "sudo"
          or . == "sudo-limited"
          or . == "sudo-limited-user"
          or . == "limited-sudo"
          or . == "admin"
          or . == "administrator"
          or . == "root"
          or . == "root-equivalent"
          or . == "admin/root-equivalent"
      );
    def valid_caps($fallback_seconds; $fallback_connections):
      type == "object"
      and (field_or("max_time_seconds"; $fallback_seconds) | valid_integer(86400))
      and (field_or("max_connections"; $fallback_connections) | valid_integer(10))
      and ((has("access_level") | not) or (.access_level | valid_access_level));

    if type != "object" then error("policy root must be an object") else . end
    | . as $policy
    | (
        if has("default") then
          if .default == null then {}
          elif (.default | type) == "object" then .default
          else error("policy default must be an object")
          end
        else
          $policy
        end
      ) as $defaults
    | ($defaults | field_or("max_time_seconds"; 86400)) as $default_seconds
    | ($defaults | field_or("max_connections"; 10)) as $default_connections
    | if ($defaults | valid_caps(86400; 10)) | not then
        error("invalid default policy limits")
      else . end
    | (
        if ($policy | has("users")) then
          if $policy.users == null then {}
          elif ($policy.users | type) == "object" then $policy.users
          else error("policy users must be an object")
          end
        else
          {}
        end
      ) as $users
    | if ($users | all(.[]; valid_caps($default_seconds; $default_connections))) | not then
        error("invalid user policy limits")
      else . end
    | ($users[$target] // {}) as $user_caps
    | ($user_caps | field_or("max_time_seconds"; $default_seconds)),
      ($user_caps | field_or("max_connections"; $default_connections))
  ' "$path")" || return $?

  [[ -n "$(printf '%s\n' "$values" | sed -n '1p')" ]] || return 2
  [[ -n "$(printf '%s\n' "$values" | sed -n '2p')" ]] || return 2
  [[ -z "$(printf '%s\n' "$values" | sed -n '3p')" ]] || return 2
  printf '%s\n' "$values"
}

if [[ -e "$policy_file" || -L "$policy_file" ]]; then
  if [[ ! -r "$policy_file" ]]; then
    audit_log session_rejected reason=unreadable_policy policy_file="$policy_file"
    echo "Cannot read sshfling policy file: $policy_file" >&2
    exit 2
  fi
  if policy_values="$(read_policy_limits "$policy_file" "$login_user")"; then
    :
  else
    policy_status="$?"
    audit_log session_rejected reason=invalid_policy policy_file="$policy_file"
    echo "Invalid sshfling policy file: $policy_file" >&2
    if [[ "$policy_status" -eq 127 ]]; then
      exit 127
    fi
    exit 2
  fi
  max_allowed_seconds="$(printf '%s\n' "$policy_values" | sed -n '1p')"
  max_allowed_connections="$(printf '%s\n' "$policy_values" | sed -n '2p')"
fi

if [[ -n "$grant_max_connections" ]]; then
  max_allowed_connections="$grant_max_connections"
fi

if [[ ! "$max_seconds" =~ ^[1-9][0-9]*$ ]]; then
  echo "Invalid --max-seconds value." >&2
  exit 2
fi

if [[ ! "$max_allowed_seconds" =~ ^[1-9][0-9]*$ ]] || (( max_allowed_seconds > 86400 )); then
  echo "Invalid sshfling policy max_time_seconds." >&2
  exit 2
fi

if [[ ! "$max_allowed_connections" =~ ^[1-9][0-9]*$ ]] || (( max_allowed_connections > 10 )); then
  echo "Invalid sshfling policy max_connections." >&2
  exit 2
fi

if (( max_seconds > max_allowed_seconds )); then
  echo "Temporary SSH session limit cannot exceed ${max_allowed_seconds} seconds." >&2
  exit 2
fi

if [[ -n "$expires_at" ]]; then
  if [[ ! "$expires_at" =~ ^[1-9][0-9]*$ ]]; then
    echo "Invalid --expires-at value." >&2
    exit 2
  fi
  now="$(date +%s)"
  if (( now >= expires_at )); then
    audit_log session_rejected reason=expired expires_at="$expires_at"
    echo "Temporary SSH access expired." >&2
    exit 124
  fi
  remaining_seconds=$(( expires_at - now ))
  if (( remaining_seconds < max_seconds )); then
    max_seconds="$remaining_seconds"
  fi
fi

status=0
timed_out=0
max_sessions="$max_allowed_connections"
uid="$(id -u)"
slot_fd=""
session_deadline=$(( $(date +%s) + max_seconds ))
export SSHFLING_SESSION_ACTIVE=1
export SSHFLING_SESSION_EXPIRES_AT="$session_deadline"
export SSHFLING_FORCED_SESSION=1
export SSHFLING_FORCED_SESSION_EXPIRES_AT="$session_deadline"
if [[ "$allow_detached_start" -eq 1 ]]; then
  export SSHFLING_FORCED_SESSION_ALLOW_DETACHED=1
else
  unset SSHFLING_FORCED_SESSION_ALLOW_DETACHED
fi
audit_log session_attempt max_seconds="$max_seconds" expires_at="$session_deadline" max_connections="$max_sessions" allow_detached_start="$allow_detached_start" original_command_present="$([[ -n "${SSH_ORIGINAL_COMMAND:-}" ]] && printf 1 || printf 0)"

open_lock_fd() {
  case "$1" in
    10) exec 10<"$2" ;;
    11) exec 11<"$2" ;;
    12) exec 12<"$2" ;;
    13) exec 13<"$2" ;;
    14) exec 14<"$2" ;;
    15) exec 15<"$2" ;;
    16) exec 16<"$2" ;;
    17) exec 17<"$2" ;;
    18) exec 18<"$2" ;;
    19) exec 19<"$2" ;;
    *) return 2 ;;
  esac
}

close_lock_fd() {
  case "$1" in
    10) exec 10>&- ;;
    11) exec 11>&- ;;
    12) exec 12>&- ;;
    13) exec 13>&- ;;
    14) exec 14>&- ;;
    15) exec 15>&- ;;
    16) exec 16>&- ;;
    17) exec 17>&- ;;
    18) exec 18>&- ;;
    19) exec 19>&- ;;
    *) return 2 ;;
  esac
}

if command -v flock >/dev/null 2>&1; then
  lock_backend=flock
elif command -v lockf >/dev/null 2>&1; then
  lock_backend=lockf
else
  echo "flock or lockf is required for sshfling connection limits." >&2
  exit 127
fi

acquire_lock_fd() {
  local fd="$1"
  local lock_status

  if [[ "$lock_backend" == flock ]]; then
    flock -n "$fd" && return 0
    lock_status="$?"
  else
    lockf -s -t 0 "$fd" && return 0
    lock_status="$?"
  fi
  if [[ "$lock_status" -eq 1 || "$lock_status" -eq 75 ]]; then
    return 1
  fi
  echo "$lock_backend could not acquire sshfling session lock FD $fd (exit $lock_status)." >&2
  return 2
}

lock_root="${session_lock_root%/}/${uid}"
validate_lock_path_components "$lock_root" 1 || {
  audit_log session_rejected reason=unsafe_lock_path lock_root="$lock_root"
  echo "Missing or unsafe root-managed sshfling session locks for uid $uid." >&2
  exit 75
}

slot=1
while (( slot <= max_sessions )); do
  lock_file="${lock_root}/session-${slot}.lock"
  if [[ ! -f "$lock_file" || -L "$lock_file" ]]; then
    echo "Missing or unsafe sshfling session lock file: $lock_file" >&2
    exit 75
  fi
  lock_owner="$(stat_number %u %u "$lock_file")" || exit 75
  [[ "$lock_owner" == "$uid" ]] || {
    echo "Incorrect owner for sshfling session lock file: $lock_file" >&2
    exit 75
  }
  candidate_fd=$(( slot + 9 ))
  open_lock_fd "$candidate_fd" "$lock_file" || {
    echo "Could not open sshfling session lock file: $lock_file" >&2
    exit 75
  }
  if acquire_lock_fd "$candidate_fd"; then
    slot_fd="$candidate_fd"
    break
  else
    acquire_status="$?"
  fi
  close_lock_fd "$candidate_fd"
  [[ "$acquire_status" -eq 1 ]] || exit 75
  slot=$(( slot + 1 ))
done
if [[ -z "$slot_fd" ]]; then
  audit_log session_rejected reason=max_sessions max_connections="$max_sessions"
  echo "Maximum active sshfling sessions reached for ${USER:-uid-$uid}." >&2
  exit 75
fi
audit_log session_start max_seconds="$max_seconds" expires_at="$session_deadline" max_connections="$max_sessions" allow_detached_start="$allow_detached_start" original_command_present="$([[ -n "${SSH_ORIGINAL_COMMAND:-}" ]] && printf 1 || printf 0)"

kill_tree() {
  local pid="$1"
  local signal="$2"
  local children

  children="$(pgrep -P "$pid" 2>/dev/null || true)"
  for child in $children; do
    kill_tree "$child" "$signal"
  done

  kill "-$signal" "$pid" 2>/dev/null || true
}

run_limited() {
  (
    exec 10>&-
    exec 11>&-
    exec 12>&-
    exec 13>&-
    exec 14>&-
    exec 15>&-
    exec 16>&-
    exec 17>&-
    exec 18>&-
    exec 19>&-
    exec "$@"
  ) &
  local command_pid="$!"
  local deadline
  deadline="$session_deadline"

  while kill -0 "$command_pid" 2>/dev/null; do
    if (( $(date +%s) >= deadline )); then
      timed_out=1
      kill_tree "$command_pid" TERM
      sleep 5
      kill_tree "$command_pid" KILL
      break
    fi
    sleep 1
  done

  wait "$command_pid" || status=$?

  if [[ "$timed_out" -eq 1 ]]; then
    status=124
  fi
}

session_shell="${SSHFLING_SESSION_SHELL:-${BASH:-}}"
if [[ -z "$session_shell" || ! -x "$session_shell" ]]; then
  session_shell="$(command -v bash || true)"
fi
if [[ -z "$session_shell" || ! -x "$session_shell" ]]; then
  echo "bash is required to run the SSHFling forced session." >&2
  exit 127
fi

if [[ -n "${SSH_ORIGINAL_COMMAND:-}" ]]; then
  run_limited "$session_shell" -lc "$SSH_ORIGINAL_COMMAND"
else
  echo "Temporary SSH session ${username} is limited to ${max_seconds} seconds." >&2
  run_limited "$session_shell" -l
fi

if [[ "$timed_out" -eq 1 ]]; then
  echo "Temporary SSH session time limit reached after ${max_seconds} seconds." >&2
fi

audit_log session_end status="$status" timed_out="$timed_out" max_seconds="$max_seconds" expires_at="$session_deadline"
exit "$status"
