# Install as /etc/sshfling/sshflingd.env with owner root, group sshflingd, mode 0640.
SSHFLING_ISSUER_TOKEN=replace-with-a-long-random-token
SSHFLING_LISTEN=127.0.0.1:8787
SSHFLING_CA_KEY=/etc/sshfling/ca_user_ed25519
SSHFLING_ALLOWED_PRINCIPALS=deploy
SSHFLING_DEFAULT_SECONDS=300
SSHFLING_MAX_SECONDS=86400
SSHFLING_SESSION_WRAPPER=/usr/local/libexec/sshfling-session
# Keep disabled for loopback-only binding. Set to 1 only when SSHFLING_LISTEN
# uses a non-loopback address behind approved network controls.
SSHFLING_ALLOW_REMOTE=0
