FROM debian:bookworm-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    openssh-client \
    openssh-server \
    openssl \
    procps \
    python3 \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/sshfling
COPY . /opt/sshfling

RUN chmod 0755 \
    /opt/sshfling/bin/sshfling \
    /opt/sshfling/production/sshfling-session \
    /opt/sshfling/tests/docker/run-production-test.sh \
  && mkdir -p /run/sshd

CMD ["/opt/sshfling/tests/docker/run-production-test.sh"]
